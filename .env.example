# Copy this file to .env.local (which is gitignored) and fill in the keys for
# the backends you want to use:
#
#     cp .env.example .env.local
#
# The example justfiles load .env.local from this repo root automatically.

# https://app.daytona.io — required for the Daytona backend (the default)
DAYTONA_API_KEY=

# https://e2b.dev/dashboard — required for the E2B backend (--backend e2b)
E2B_API_KEY=
